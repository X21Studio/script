--// SERVICES
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

--// VARS
local LocalPlayer = Players.LocalPlayer
local enabled = false
local highlights = {}

--// VIP CHECK
local function isPlayerVIP(player)
    local tag = player:FindFirstChild("IsVIP")
    if tag and tag:IsA("BoolValue") and tag.Value == true then
        return true
    end

    local ls = player:FindFirstChild("leaderstats")
    if ls then
        local tag2 = ls:FindFirstChild("IsVIP")
        if tag2 and tag2:IsA("BoolValue") and tag2.Value == true then
            return true
        end
    end

    if player.Character then
        local tag3 = player.Character:FindFirstChild("IsVIP")
        if tag3 and tag3:IsA("BoolValue") and tag3.Value == true then
            return true
        end
    end

    return false
end

--// MOD CHECK (HDAdminStarterCharacter)
local function isMod(player)
    local char = player.Character
    if not char then return false end

    -- név alapú check (HD admin sokszor így spawnolja)
    if char:FindFirstChild("HDAdminStarterCharacter") then
        return true
    end

    -- extra safety: név string check is
    if player.Name == "HDAdminStarterCharacter" then
        return true
    end

    return false
end

--// HIGHLIGHT ADD
local function addHighlight(player)
    if not player.Character then return end
    if highlights[player] then return end

    local hl = Instance.new("Highlight")

    -- MOD = KÉK 💙
    if isMod(player) then
        hl.FillColor = Color3.fromRGB(0, 170, 255)
        hl.OutlineColor = Color3.fromRGB(255, 255, 255)

    -- VIP = ARANY ✨
    elseif isPlayerVIP(player) then
        hl.FillColor = Color3.fromRGB(255, 215, 0)
        hl.OutlineColor = Color3.fromRGB(255, 255, 255)

    else
        return
    end

    hl.FillTransparency = 0.4
    hl.Parent = player.Character

    highlights[player] = hl
end

--// REMOVE
local function removeHighlight(player)
    if highlights[player] then
        highlights[player]:Destroy()
        highlights[player] = nil
    end
end

--// UPDATE
local function updateAll()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if enabled and (isPlayerVIP(player) or isMod(player)) then
                addHighlight(player)
            else
                removeHighlight(player)
            end
        end
    end
end

--// NEW PLAYER
Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function()
        task.wait(1)
        updateAll()
    end)
end)

--// EXISTING
for _, player in pairs(Players:GetPlayers()) do
    if player.Character then
        player.CharacterAdded:Connect(function()
            task.wait(1)
            updateAll()
        end)
    end
end

--// KEYBIND
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end

    if input.KeyCode == Enum.KeyCode.K then
        enabled = not enabled
        print("Highlight:", enabled and "ON" or "OFF")
        updateAll()
    end
end)
