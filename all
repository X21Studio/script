local scripts = {
    "https://raw.githubusercontent.com/X21Studio/script/main/SystemBroken",
    "https://raw.githubusercontent.com/X21Studio/script/main/Player%20Notes",
    "https://raw.githubusercontent.com/X21Studio/script/main/vip-esp",
    "https://raw.githubusercontent.com/X21Studio/script/main/Backpack%20%2B%20AntiPush"
}

for _, url in ipairs(scripts) do
    local success, err = pcall(function()
        loadstring(game:HttpGet(url))()
    end)

    if not success then
        warn("Failed to load:", url, err)
    end
end
