-- FUNKCIÓK
local function getPlayerFromPart(part)
    local character = part
    while character and character ~= workspace do
        if character:FindFirstChildOfClass("Humanoid") then
            local player = Players:GetPlayerFromCharacter(character)
            if player and player ~= LocalPlayer then
                return player
            end
        end
        character = character.Parent
    end
    return nil
end

local function checkAntiPush(player)
    local path = "Players > " .. player.Name .. " > "
    local tagSettings = player:FindFirstChild("TagSettings") or player:FindFirstChild("TagSetting")
    
    if not tagSettings then
        AntiPushPath.Text = path .. "[❌ TagSettings NINCS]"
        return false
    end
    
    path = path .. tagSettings.Name .. " > "
    local antiPushValue = tagSettings:FindFirstChild("AntiPush")
    
    if not antiPushValue then
        AntiPushPath.Text = path .. "[❌ AntiPush NINCS]"
        return false
    end
    
    path = path .. "AntiPush"
    local hasAntiPush = (antiPushValue.Value == true or antiPushValue.Value == 1)
    
    AntiPushPath.Text = path .. (hasAntiPush and " ✅" or " ❌")
    return hasAntiPush
end

local function createItemLabel(name, index)
    local ItemFrame = Instance.new("Frame")
    ItemFrame.Name = "Item_" .. index
    ItemFrame.Parent = ScrollFrame
    ItemFrame.BackgroundColor3 = Color3.fromRGB(50, 50, 65)
    ItemFrame.Size = UDim2.new(1, 0, 0, 35)
    
    local ItemCorner = Instance.new("UICorner")
    ItemCorner.CornerRadius = UDim.new(0, 8)
    ItemCorner.Parent = ItemFrame
    
    local ItemLabel = Instance.new("TextLabel")
    ItemLabel.Parent = ItemFrame
    ItemLabel.BackgroundTransparency = 1
    ItemLabel.Size = UDim2.new(1, -10, 1, 0)
    ItemLabel.Position = UDim2.new(0, 10, 0, 0)
    ItemLabel.Font = Enum.Font.Gotham
    ItemLabel.Text = "🎒 " .. name
    ItemLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    ItemLabel.TextSize = 14
    ItemLabel.TextXAlignment = Enum.TextXAlignment.Left
    
    return ItemFrame
end

local function clearInventoryList()
    for _, child in pairs(ScrollFrame:GetChildren()) do
        if child:IsA("Frame") and child.Name:match("Item_") then
            child:Destroy()
        end
    end
end

local function updateDisplay(player)
    if not player or not player.Parent then return end
    
    Title.Text = "👤 " .. player.Name .. " - Inventory + AntiPush"
    
    -- AntiPush ellenőrzés
    checkAntiPush(player)
    
    -- Backpack lista
    clearInventoryList()
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        local items = backpack:GetChildren()
        for i, item in pairs(items) do
            if item:IsA("Tool") or item:IsA("HopperBin") then
                createItemLabel(item.Name, i)
            end
        end
    end
    
    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y + 10)
end

local function selectPlayer(newPlayer)
    if highlight then
        highlight:Destroy()
    end
    
    selectedPlayer = newPlayer
    if selectedPlayer and selectedPlayer.Character then
        highlight = Instance.new("Highlight")
        highlight.Parent = selectedPlayer.Character
        highlight.FillColor = Color3.fromRGB(0, 162, 255)
        highlight.FillTransparency = 0.5
        highlight.OutlineColor = Color3.fromRGB(0, 162, 255)
    end
    
    updateDisplay(selectedPlayer)
end

local function deselectPlayer()
    if highlight then
        highlight:Destroy()
        highlight = nil
    end
    selectedPlayer = nil
    Title.Text = "🎒 Inventory + 🔍 AntiPush Viewer"
    AntiPushPath.Text = "Players > Név > TagSettings > AntiPush"
    clearInventoryList()
    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
end

-- ESEMÉNYEK
CloseButton.MouseButton1Click:Connect(deselectPlayer)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.M then
        guiOpen = not guiOpen
        MainFrame.Visible = guiOpen
        if not guiOpen then
            deselectPlayer()
        end
    end
end)

Mouse.Button1Down:Connect(function()
    if not guiOpen then return end
    
    local target = Mouse.Target
    if target then
        local player = getPlayerFromPart(target)
        if player then
            selectPlayer(player)
        else
            deselectPlayer()
        end
    end
end)

